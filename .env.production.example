# =============================================================================
# A2Z Tools — Production Environment Template
# Copy to .env on the origin host. NEVER commit filled values to git.
# Store secrets in GitHub Environments / AWS Secrets Manager / 1Password.
# =============================================================================

# --- Domains (replace a2ztools.com with your domain) ---
NEXT_PUBLIC_API_URL=https://api.a2ztools.com/api/v1
NEXT_PUBLIC_SITE_URL=https://www.a2ztools.com
NEXT_PUBLIC_ADMIN_URL=https://dashboard.a2ztools.com
FRONTEND_URL=https://www.a2ztools.com

# --- Django / API ---
DJANGO_SETTINGS_MODULE=config.settings.prod
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=api.a2ztools.com
DJANGO_CORS_ALLOWED_ORIGINS=https://www.a2ztools.com,https://dashboard.a2ztools.com
CSRF_TRUSTED_ORIGINS=https://www.a2ztools.com,https://dashboard.a2ztools.com,https://api.a2ztools.com
DJANGO_SECURE_SSL_REDIRECT=False
NEXT_PUBLIC_ADMIN_DEMO=false

# --- PostgreSQL (internal Docker network only) ---
POSTGRES_DB=a2z_tools
POSTGRES_USER=a2z
POSTGRES_PASSWORD=
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# --- JWT ---
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_COOKIE_DOMAIN=.a2ztools.com
JWT_AUTH_COOKIE_SAMESITE=None
JWT_AUTH_COOKIE_ONLY=true

# --- Nginx (host ports) ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Container images (set by CI/CD; leave empty for local build) ---
IMAGE_TAG=
BACKEND_IMAGE=
FRONTEND_IMAGE=

# --- Backups (S3 or Cloudflare R2) ---
BACKUP_S3_BUCKET=a2z-tools-prod-backups
AWS_DEFAULT_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Email (transactional) ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@a2ztools.com.au

# --- Stripe (production keys) ---
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Object storage (product media) ---
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-2

# --- Observability (optional) ---
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# --- Demo / payments ---
DEMO_AUTO_COMPLETE_PAYMENTS=False
