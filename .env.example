# =============================================================================
# A2Z Tools — Root Environment Variables
# Copy to .env and adjust for local development
# =============================================================================

# PostgreSQL
POSTGRES_DB=a2z_tools
POSTGRES_USER=a2z
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5433

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_HOST_PORT=6380

# pgAdmin (development / ops)
PGADMIN_DEFAULT_EMAIL=admin@a2ztools.local
PGADMIN_DEFAULT_PASSWORD=changeme
PGADMIN_HOST_PORT=5050

# Service ports (host)
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-secure-random-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,api.localhost
DJANGO_DEBUG=True
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Frontend
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (optional in dev)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (optional in dev)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@a2ztools.com.au

# AWS S3 / Object Storage (optional in dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-southeast-2
